  "dirs": [],
  "patterns": [],
  "files": [],
  "pre_commands": [
    "git log --reverse --format='=== COMMIT: %h ===%nTITLE: %s%n%nMESSAGE:%n%b%n%nCHANGES:%n' --stat"
