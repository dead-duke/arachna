{
  "project_name": "arachna",
  "output_dir": ".",
  "profiles": {
    "code": {
      "title_template": "# {project_name} — CODE (part {part})\n\n",
      "name_template": "chat-code",
      "split_mode": "by_file",
      "directories": ["src"],
      "patterns": ["*.py"],
      "pre_commands": ["tree -I '__pycache__|*.pyc|*.egg-info|venv' src"],
      "files": ["pyproject.toml"],
      "max_tokens": 16000
    },
    "tests": {
      "title_template": "# {project_name} — TESTS (part {part})\n\n",
      "name_template": "chat-tests",
      "split_mode": "by_file",
      "directories": ["tests"],
      "patterns": ["*.py"],
      "pre_commands": ["tree tests"],
      "max_tokens": 16000
    },
    "docs": {
      "title_template": "# {project_name} — DOCS (part {part})\n\n",
      "name_template": "chat-docs",
      "split_mode": "by_file",
      "files": ["README.md", "TODO.md", "CHANGELOG.md"],
      "pre_commands": ["tree -I '__pycache__|*.pyc|*.egg-info|venv' -L 1"],
      "max_tokens": 16000
    },
    "git": {
      "title_template": "# {project_name} — GIT HISTORY (part {part})\n\n",
      "name_template": "chat-git",
      "split_mode": "by_marker",
      "split_marker": "\n\n=== COMMIT:",
      "command": "git log --reverse --format='=== COMMIT: %h ===%nTITLE: %s%n%nMESSAGE:%n%b%n%nCHANGES:%n' --stat",
      "max_tokens": 16000
    }
  }
}
