{
  "project_name": "arachna",
  "output_dir": "arachna_context",
  "profiles": {
    "all": {
      "title_template": "# {project_name} — FULL CONTEXT (part {part})\n\n",
      "name_template": "chat-all",
      "split_mode": "by_file",
      "directories": ["src", "tests", "llm_docs", ".github"],
      "patterns": ["*.py", "*.md", "*.txt", "*.json", "*.toml", "*.yaml", "*.yml", "*.cfg", "*.ini"],
      "files": [".arachna.json", ".gitignore", "pyproject.toml", "README.md", "TODO.md", "CHANGELOG.md", "Makefile", "LICENSE", "requirements-dev.txt", ".pre-commit-config.yaml"],
      "pre_commands": [
        "tree -I '__pycache__|*.pyc|*.egg-info|venv|arachna_context' -L 2"
      ],
      "max_tokens": 32768
    }
  }
}
