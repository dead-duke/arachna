{
  "project_name": "arachna",
  "output_dir": "arachna_context",
  "profiles": {
    "full": {
      "title_template": "# {project_name} — FULL CONTEXT (part {part} of {total})\n\n",
      "name_template": "chat-full",
      "split_mode": "by_file",
      "directories": ["src", "tests", "llm_docs", ".github", "docs", "examples"],
      "patterns": ["*.py", "*.md", "*.txt", "*.json", "*.toml", "*.yaml", "*.yml", "*.cfg", "*.ini"],
      "exclude_patterns": ["*sonarcloud/vulnerabilities.md", "*sonarcloud/bugs.md", "*sonarcloud/code_smells.md", "*sonarcloud/security_hotspots.md"],
      "files": [
        ".arachna.json",
        ".gitignore",
        "pyproject.toml",
        "README.md",
        "TODO.md",
        "CHANGELOG.md",
        "Makefile",
        "LICENSE",
        "SECURITY.md",
        "requirements-dev.txt",
        ".pre-commit-config.yaml",
        "MANIFEST.in",
        "arachna.1"
      ],
      "pre_commands": [
        "tree -I '__pycache__|*.pyc|*.egg-info|venv|arachna_context' -L 2",
        "git tag --sort=-creatordate",
        "git log --reverse --format='=== COMMIT: %h ===%nTITLE: %s%n%nMESSAGE:%n%b%n'"
      ],
      "max_tokens": 32768,
      "use_gitignore": false
    },
    "dev": {
      "title_template": "# {project_name} — DEV (part {part} of {total})\n\n",
      "name_template": "chat-dev",
      "split_mode": "by_file",
      "directories": ["src", "tests", "llm_docs", ".github", "examples"],
      "patterns": ["*.py", "*.md", "*.yaml", "*.yml", "*.json", "*.toml", "*.cfg", "*.ini"],
      "exclude_patterns": ["*sonarcloud/vulnerabilities.md", "*sonarcloud/bugs.md", "*sonarcloud/code_smells.md", "*sonarcloud/security_hotspots.md"],
      "files": [
        ".arachna.json",
        ".gitignore",
        "pyproject.toml",
        "TODO.md",
        "Makefile",
        "requirements-dev.txt",
        ".pre-commit-config.yaml"
      ],
      "pre_commands": [
        "tree -I '__pycache__|*.pyc|*.egg-info|venv|arachna_context' -L 2",
        "git tag --sort=-creatordate"
      ],
      "max_tokens": 32768,
      "use_gitignore": false
    },
    "docs": {
      "split_mode": "by_file",
      "directories": ["docs", "llm_docs"],
      "patterns": ["*.md", "*.txt"],
      "files": ["README.md", "CHANGELOG.md", "TODO.md", "Makefile", "LICENSE", "SECURITY.md", "arachna.1"],
      "pre_commands": ["tree docs llm_docs 2>/dev/null || true"],
      "max_tokens": 32768,
      "use_gitignore": false
    },
    "config": {
      "split_mode": "by_file",
      "directories": [],
      "patterns": [],
      "files": [".arachna.json", "pyproject.toml", "Makefile", ".pre-commit-config.yaml", "requirements-dev.txt"],
      "pre_commands": [],
      "max_tokens": 32768,
      "use_gitignore": false
    }
  }
}
